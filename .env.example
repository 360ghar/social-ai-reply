APP_NAME=RedditFlow
ENVIRONMENT=development
DATABASE_URL=sqlite:///./poacher.db
AUTO_CREATE_TABLES=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

ENCRYPTION_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
USE_MOCK_LLM=false

# Gemini (primary LLM)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
REDDIT_BASE_URL=https://www.reddit.com
REDDIT_USER_AGENT=redditflow/1.0

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SMTP_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_DIR=./sessions
INSTAGRAM_CHALLENGE_CODE=
PROXY_URLS=
SCRAPE_REQUESTS_PER_MINUTE=30
SCRAPE_DAILY_CAP_PER_ACCOUNT=2500
