APP_NAME=RedditFlow
ENVIRONMENT=development
DATABASE_URL=sqlite:///./poacher.db
AUTO_CREATE_TABLES=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret

ENCRYPTION_KEY=

# LLM Provider selection (openai, gemini, perplexity, claude)
LLM_PROVIDER=openai

# OpenAI (primary)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

REDDIT_BASE_URL=https://www.reddit.com
REDDIT_USER_AGENT=redditflow/1.0

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SMTP_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_DIR=./sessions
INSTAGRAM_CHALLENGE_CODE=
PROXY_URLS=
SCRAPE_REQUESTS_PER_MINUTE=30
SCRAPE_DAILY_CAP_PER_ACCOUNT=2500
