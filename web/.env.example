NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Client-side logging — ships browser errors/events to POST /v1/telemetry/client-event
# Default ON. Set to "0" or "false" to disable entirely (kill-switch).
NEXT_PUBLIC_CLIENT_LOGGING=1
# Sample rate (0..1) for non-error events (info/warning). Errors always pass.
# Default 0.1 (10%). Set to 1 to capture everything.
NEXT_PUBLIC_CLIENT_LOG_SAMPLE=0.1

